<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>D&V Custom Tile & Marble</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:#0d0b08;color:#ede9e2;overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
:root{
  --y:#d4b84a;--yb:#e8cc5a;
  --bg:#0d0b08;--panel:#141009;
  --cream:#ede9e2;--stone:#7a7060;
  --bdr:rgba(212,184,74,0.22);--nh:68px;
}
/* NAV */
#nav{position:fixed;top:0;left:0;right:0;height:var(--nh);display:flex;align-items:center;justify-content:space-between;padding:0 5vw;z-index:500;transition:background .3s;}
#nav.s{background:rgba(13,11,8,.97);box-shadow:0 1px 0 var(--bdr);backdrop-filter:blur(12px);}
.nl{display:flex;align-items:center;gap:12px;}
.nwt{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#ede9e2;letter-spacing:.06em;line-height:1.1;}
.nwb{font-family:'Jost',sans-serif;font-size:.55rem;font-weight:300;color:rgba(212,184,74,.7);letter-spacing:.25em;text-transform:uppercase;}
.nls{display:flex;gap:2rem;list-style:none;}
.nls a{font-size:.7rem;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:rgba(237,233,226,.4);transition:color .2s;}
.nls a:hover{color:var(--y);}
.nc{background:var(--y);color:#0d0b08;border:none;padding:.62rem 1.5rem;font-family:'Jost',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;}
.nc:hover{background:var(--yb);}
.hb{display:none;flex-direction:column;gap:5px;background:none;border:none;padding:5px;cursor:pointer;}
.hb span{display:block;width:22px;height:1.5px;background:var(--cream);}
#mm{display:none;position:fixed;inset:0;z-index:490;background:#0d0b08;flex-direction:column;align-items:center;justify-content:center;gap:1.8rem;}
#mm.open{display:flex;}
#mm a{font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:300;color:var(--cream);}
#mm a:hover{color:var(--y);}
.mc{background:var(--y);color:#0d0b08;border:none;padding:.9rem 2.5rem;font-family:'Jost',sans-serif;font-size:.78rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;margin-top:.5rem;}
/* SHARED */
.sec{padding:5.5rem 5vw;}
.ey{font-size:.64rem;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:var(--y);display:flex;align-items:center;gap:.7rem;margin-bottom:.9rem;}
.ey::before{content:'';width:20px;height:1px;background:var(--y);display:block;flex-shrink:0;}
.sh{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.4rem,4.5vw,5.5rem);line-height:.94;color:var(--cream);letter-spacing:.03em;}
.sh span{color:var(--y);}
.sp{font-size:.9rem;color:rgba(237,233,226,.45);line-height:1.9;font-weight:300;max-width:480px;}
.btn{display:inline-flex;align-items:center;padding:.85rem 1.8rem;font-family:'Jost',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;border:none;cursor:pointer;transition:all .25s;text-decoration:none;}
.by{background:var(--y);color:#0d0b08;}.by:hover{background:var(--yb);}
.bo{background:transparent;color:var(--cream);border:1.5px solid rgba(237,233,226,.25);}.bo:hover{border-color:var(--y);color:var(--y);}
/* HERO */
#hero{min-height:100vh;padding-top:var(--nh);display:grid;grid-template-columns:1fr 1fr;background:var(--bg);position:relative;overflow:hidden;}
#hero::before{content:'';position:absolute;inset:0;pointer-events:none;background-image:repeating-linear-gradient(0deg,transparent,transparent 59px,rgba(212,184,74,.04) 59px,rgba(212,184,74,.04) 60px),repeating-linear-gradient(90deg,transparent,transparent 59px,rgba(212,184,74,.04) 59px,rgba(212,184,74,.04) 60px);}
.hl{display:flex;flex-direction:column;justify-content:center;gap:2rem;padding:4rem 4vw 4rem 6vw;position:relative;z-index:1;}
.hh{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.8rem,7.5vw,10rem);line-height:.88;color:var(--cream);letter-spacing:.02em;}
.hh span{color:var(--y);display:block;}
.hp2{font-size:.95rem;color:rgba(237,233,226,.48);line-height:1.9;font-weight:300;max-width:420px;}
.hbtns{display:flex;gap:1rem;flex-wrap:wrap;}
.hst{display:flex;gap:2.5rem;padding-top:1.5rem;border-top:1px solid rgba(212,184,74,.2);flex-wrap:wrap;}
.hsn{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;color:var(--y);line-height:1;}
.hsl{font-size:.6rem;color:rgba(237,233,226,.3);letter-spacing:.14em;text-transform:uppercase;margin-top:2px;}
.hr{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;gap:3px;min-height:calc(100vh - var(--nh));}
.hp{overflow:hidden;position:relative;}
.hp:first-child{grid-row:span 2;}
.hp img{width:100%;height:100%;object-fit:cover;object-position:center;display:block;transition:transform .7s;}
.hp:hover img{transform:scale(1.05);}
.hpl{position:absolute;bottom:.8rem;left:.9rem;z-index:2;font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:var(--y);background:rgba(13,11,8,.7);padding:.22rem .55rem;}
/* MARQUEE */
.mq{background:var(--y);overflow:hidden;padding:.85rem 0;white-space:nowrap;}
.mqi{display:inline-flex;animation:mq 25s linear infinite;}
@keyframes mq{to{transform:translateX(-50%);}}
.mqit{display:inline-flex;align-items:center;gap:1.2rem;padding:0 2rem;font-family:'Bebas Neue',sans-serif;font-size:.95rem;color:#0d0b08;letter-spacing:.08em;}
.mqd{width:4px;height:4px;background:#0d0b08;border-radius:50%;opacity:.4;flex-shrink:0;}
/* PORTFOLIO */
#portfolio{background:var(--panel);}
.ph{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:end;margin-bottom:3rem;}
.r1{display:grid;grid-template-columns:2fr 1fr 1fr;gap:5px;margin-bottom:5px;}
.r1c{overflow:hidden;position:relative;background:#111;height:400px;}
.r2{display:grid;grid-template-columns:repeat(5,1fr);gap:5px;}
.r2c{overflow:hidden;position:relative;background:#111;height:260px;}
.r1c img,.r2c img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;transition:transform .6s;}
.r1c:hover img,.r2c:hover img{transform:scale(1.05);}
.pov{position:absolute;bottom:0;left:0;right:0;padding:1.2rem;background:linear-gradient(to top,rgba(13,11,8,.92),transparent 65%);opacity:0;transform:translateY(4px);transition:all .3s;z-index:2;}
.r1c:hover .pov,.r2c:hover .pov{opacity:1;transform:none;}
.pn{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--cream);}
.pd{font-size:.64rem;color:var(--y);letter-spacing:.1em;text-transform:uppercase;margin-top:2px;}
.pb{position:absolute;top:.9rem;left:.9rem;z-index:3;background:var(--y);color:#0d0b08;font-size:.56rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;padding:.24rem .6rem;}
/* VISUALIZER */
#viz{background:var(--bg);}
.vh{text-align:center;max-width:560px;margin:0 auto 3rem;display:flex;flex-direction:column;align-items:center;gap:1rem;}
.vh .ey{justify-content:center;}.vh .ey::before{display:none;}
.vbox{border:1px solid var(--bdr);background:var(--panel);overflow:hidden;max-width:1060px;margin:0 auto;}
.vin{min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2rem;padding:4rem 2rem;position:relative;overflow:hidden;}
.vin::before{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 20px,rgba(212,184,74,.025) 20px,rgba(212,184,74,.025) 21px);}
.vbg{background:var(--y);color:#0d0b08;padding:.28rem 1rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;font-weight:700;position:relative;z-index:1;}
.vt{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.2rem,4vw,4rem);color:var(--cream);text-align:center;letter-spacing:.04em;line-height:1.05;position:relative;z-index:1;}
.vt span{color:var(--y);}
.vs{font-size:.88rem;color:rgba(237,233,226,.42);text-align:center;max-width:440px;line-height:1.8;position:relative;z-index:1;}
.vsteps{display:flex;gap:2.5rem;flex-wrap:wrap;justify-content:center;position:relative;z-index:1;}
.vstep{display:flex;flex-direction:column;align-items:center;gap:.55rem;max-width:105px;text-align:center;}
.vsi{width:48px;height:48px;border-radius:50%;background:rgba(212,184,74,.1);border:1px solid var(--bdr);color:var(--y);font-size:1.25rem;display:flex;align-items:center;justify-content:center;}
.vsl{font-size:.7rem;color:rgba(237,233,226,.38);line-height:1.5;}
.vn{background:rgba(212,184,74,.08);border:1px solid var(--bdr);padding:1.2rem 1.8rem;max-width:500px;width:100%;position:relative;z-index:1;text-align:center;}
.vn p{font-size:.82rem;color:rgba(237,233,226,.5);line-height:1.7;}
.vn strong{color:var(--y);}
.vbtns{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;position:relative;z-index:1;}
/* SERVICES */
#services{background:var(--panel);}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(212,184,74,.08);margin-top:3rem;border:1px solid rgba(212,184,74,.08);}
.sv{background:var(--bg);padding:2.5rem 2rem;border:1px solid transparent;transition:all .3s;}
.sv:hover{background:#14100a;border-color:rgba(212,184,74,.25);}
.svn{font-size:.62rem;color:rgba(212,184,74,.5);letter-spacing:.12em;font-weight:600;margin-bottom:1.2rem;}
.svi{font-size:1.8rem;margin-bottom:1rem;}
.svt{font-size:.95rem;font-weight:600;color:var(--cream);margin-bottom:.6rem;}
.svb{font-size:.83rem;color:rgba(237,233,226,.4);line-height:1.85;}
/* PROCESS */
#process{background:var(--bg);}
.pg{display:grid;grid-template-columns:repeat(4,1fr);margin-top:3.5rem;}
.ps{position:relative;padding:0 2rem 2rem 0;}
.ps:not(:last-child)::after{content:'';position:absolute;top:18px;left:36px;right:0;height:1px;background:rgba(212,184,74,.15);}
.psn{width:36px;height:36px;border-radius:50%;background:rgba(212,184,74,.12);border:1px solid var(--bdr);color:var(--y);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:1rem;margin-bottom:1.3rem;position:relative;z-index:1;}
.pst{font-size:.9rem;font-weight:600;color:var(--cream);margin-bottom:.5rem;}
.psb{font-size:.82rem;color:rgba(237,233,226,.4);line-height:1.8;}
/* TEAM */
#team{background:var(--panel);}
.tg{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-top:2.5rem;}
.tc{background:var(--bg);border:1px solid var(--bdr);overflow:hidden;transition:border-color .3s;}
.tc:hover{border-color:var(--y);}
.tci{height:180px;position:relative;overflow:hidden;}
.tci canvas{width:100%;height:100%;display:block;}
.tci::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,var(--bg) 0%,transparent 55%);}
.tcb{padding:1.4rem;}
.tcn{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--cream);letter-spacing:.04em;line-height:1;}
.tcr{font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--y);opacity:.75;margin:.4rem 0 .8rem;font-weight:600;}
.tcbi{font-size:.81rem;color:rgba(237,233,226,.38);line-height:1.8;}
.tcy{display:block;margin-top:.75rem;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(237,233,226,.18);border-top:1px solid rgba(212,184,74,.1);padding-top:.55rem;}
/* REVIEWS */
#reviews{background:var(--bg);overflow:hidden;}
.rw{overflow:hidden;margin:0 -5vw;margin-top:3rem;}
.rt{display:flex;gap:1.2rem;animation:scr 42s linear infinite;width:max-content;padding:0 5vw;}
.rt:hover{animation-play-state:paused;}
@keyframes scr{to{transform:translateX(-50%);}}
.rc{width:300px;flex-shrink:0;background:var(--panel);border:1px solid var(--bdr);padding:1.6rem;display:flex;flex-direction:column;gap:.85rem;}
.rcs{color:var(--y);font-size:.82rem;}
.rct{font-size:.84rem;color:rgba(237,233,226,.65);line-height:1.85;font-style:italic;}
.rca{font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--stone);}
/* CONTACT */
#contact{display:grid;grid-template-columns:1fr 1fr;}
.cl{background:linear-gradient(160deg,#3d2a14 0%,#1a0e04 100%);padding:5rem 5vw;display:flex;flex-direction:column;gap:1.8rem;justify-content:center;border-right:1px solid rgba(212,184,74,.15);}
.cil{display:flex;flex-direction:column;gap:.9rem;margin-top:.5rem;}
.ci{display:flex;gap:.9rem;font-size:.86rem;color:rgba(237,233,226,.75);line-height:1.6;align-items:flex-start;}
.ci a{color:rgba(237,233,226,.75);transition:color .2s;}.ci a:hover{color:var(--y);}
.cr2{background:var(--panel);padding:5rem 5vw;display:flex;flex-direction:column;gap:1.2rem;}
.cr2 h3{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--cream);letter-spacing:.05em;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;}
.fu{grid-column:1/-1;}
.ff{display:flex;flex-direction:column;gap:.32rem;}
.ff label{font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;color:var(--stone);font-weight:500;}
.ff input,.ff select,.ff textarea{background:rgba(255,255,255,.04);border:1px solid rgba(212,184,74,.15);padding:.72rem .9rem;font-family:'Jost',sans-serif;font-size:.86rem;color:var(--cream);outline:none;transition:border-color .2s;width:100%;}
.ff input:focus,.ff select:focus,.ff textarea:focus{border-color:var(--y);}
.ff select option{background:#1a1508;}
.ff textarea{height:100px;resize:none;}
/* FOOTER */
footer{background:#080602;padding:3.5rem 5vw 1.8rem;}
.fc{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:2.5rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(212,184,74,.07);}
.fb p{font-size:.78rem;color:rgba(237,233,226,.22);line-height:1.9;margin-top:1rem;max-width:230px;}
.fcl h4{font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(212,184,74,.55);margin-bottom:1.1rem;font-weight:600;}
.fcl ul{list-style:none;display:flex;flex-direction:column;gap:.55rem;}
.fcl ul a{font-size:.78rem;color:rgba(237,233,226,.25);transition:color .2s;}.fcl ul a:hover{color:var(--cream);}
.fbot{padding-top:1.8rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:.5rem;font-size:.68rem;color:rgba(237,233,226,.14);}
/* RESPONSIVE */
@media(max-width:900px){
  .nls,.nc{display:none;}.hb{display:flex;}
  #hero{grid-template-columns:1fr;}
  .hl{padding:3rem 5vw;}
  .hr{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;min-height:70vw;}
  .hp:first-child{grid-row:span 1;}
  .ph{grid-template-columns:1fr;gap:1.5rem;}
  .r1{grid-template-columns:1fr 1fr;}.r1c{height:44vw;}
  .r2{grid-template-columns:repeat(3,1fr);}.r2c{height:36vw;}
  .sg{grid-template-columns:1fr 1fr;}
  .pg{grid-template-columns:1fr 1fr;gap:2rem;}.ps::after{display:none;}
  .tg{grid-template-columns:1fr 1fr;}
  #contact{grid-template-columns:1fr;}
  .fc{grid-template-columns:1fr 1fr;gap:2rem;}
}
@media(max-width:600px){
  :root{--nh:58px;}
  .hr{min-height:80vw;}
  .r1{grid-template-columns:1fr;}.r1c{height:72vw;}
  .r2{grid-template-columns:1fr 1fr;}.r2c{height:52vw;}
  .sg,.tg{grid-template-columns:1fr;}
  .pg{grid-template-columns:1fr;}
  .fr{grid-template-columns:1fr;}
  .fc{grid-template-columns:1fr;}
}
</style>
</head>
<body>
<nav id="nav">
  <div class="nl">
    <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
      <rect width="50" height="50" fill="#3d2a14"/>
      <rect x="1.5" y="1.5" width="47" height="47" fill="none" stroke="#d4b84a" stroke-width="1.5"/>
      <line x1="25" y1="1.5" x2="25" y2="48.5" stroke="#d4b84a" stroke-width="1.2"/>
      <line x1="1.5" y1="25" x2="48.5" y2="25" stroke="#d4b84a" stroke-width="1.2"/>
      <rect x="2.5" y="2.5" width="20" height="20" fill="#d4b84a" opacity="0.2"/>
      <rect x="27.5" y="27.5" width="20" height="20" fill="#d4b84a" opacity="0.2"/>
      <rect x="27.5" y="2.5" width="20" height="20" fill="#6b4c2a" opacity="0.4"/>
      <rect x="2.5" y="27.5" width="20" height="20" fill="#6b4c2a" opacity="0.4"/>
      <polygon points="25,17 33,25 25,33 17,25" fill="#3d2a14" stroke="#d4b84a" stroke-width="1.2"/>
      <text x="12.5" y="17" font-family="Georgia,serif" font-size="12" font-weight="700" fill="#d4b84a" text-anchor="middle">D</text>
      <text x="37.5" y="40.5" font-family="Georgia,serif" font-size="12" font-weight="700" fill="#d4b84a" text-anchor="middle">V</text>
      <text x="25" y="28.5" font-family="Georgia,serif" font-size="7.5" fill="#d4b84a" text-anchor="middle">&amp;</text>
    </svg>
    <div><div class="nwt">D&amp;V CUSTOM TILE</div><div class="nwb">&amp; MARBLE</div></div>
  </div>
  <ul class="nls">
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#viz">Visualizer</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#team">Team</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <button class="nc" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Free Quote</button>
  <button class="hb" id="hbg"><span></span><span></span><span></span></button>
</nav>
<div id="mm">
  <a href="#portfolio" onclick="cm()">Portfolio</a>
  <a href="#viz"       onclick="cm()">Visualizer</a>
  <a href="#services"  onclick="cm()">Services</a>
  <a href="#team"      onclick="cm()">Team</a>
  <a href="#contact"   onclick="cm()">Contact</a>
  <button class="mc" onclick="cm();document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Free Quote</button>
</div>

<section id="hero">
  <div class="hl">
    <div class="ey">Master Craftsmen &middot; Licensed &amp; Insured</div>
    <h1 class="hh">Built By<br><span>Hand.</span><br>Built<br>To Last.</h1>
    <p class="hp2">We don't just install tile &mdash; we sculpt spaces. D&amp;V Custom Tile &amp; Marble brings master-level precision to every project we touch.</p>
    <div class="hbtns">
      <a href="#portfolio" class="btn by">View Our Work</a>
      <a href="#viz" class="btn bo">Room Visualizer</a>
    </div>
    <div class="hst">
      <div><div class="hsn">500+</div><div class="hsl">Projects Done</div></div>
      <div><div class="hsn">15+</div><div class="hsl">Years Experience</div></div>
      <div><div class="hsn">5&#9733;</div><div class="hsl">Avg. Rating</div></div>
    </div>
  </div>
  <div class="hr">
    <div class="hp"><img src="data:image/jpeg;base64," alt="Steel blue marble shower" loading="eager"><span class="hpl">Steel Blue Marble Shower</span></div>
    <div class="hp"><img src="data:image/jpeg;base64," alt="Travertine rain shower" loading="eager"><span class="hpl">Travertine Rain Shower</span></div>
    <div class="hp"><img src="data:image/jpeg;base64," alt="Ornate feature wall" loading="eager"><span class="hpl">Ornate Feature Wall</span></div>
  </div>
</section>

<div class="mq"><div class="mqi" id="mqi"></div></div>

<section id="portfolio" class="sec">
  <div class="ph">
    <div>
      <div class="ey">Our Portfolio</div>
      <h2 class="sh">The <span>Work</span><br>Speaks</h2>
    </div>
    <div>
      <p class="sp">Every project is a collaboration between vision and craft. These are our hands &mdash; and our pride.</p>
      <a href="#contact" class="btn by" style="margin-top:1.2rem;display:inline-flex;">Start Your Project</a>
    </div>
  </div>
  <div class="r1">
